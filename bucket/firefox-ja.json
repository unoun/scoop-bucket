{
    "version": "148.0",
    "description": "Firefox(ja)",
    "homepage": "https://www.mozilla.org/firefox/",
    "license": "MPL-2.0",
    "notes": [
        "For policies, run 'scoop install firefox-policies'.",
        "First, make sure to run the 'Firefox Profile Manager' and set default profile, even after an update.",
        "Check the following resources to completely uninstall:",
        "- HKCU:\\Software\\Mozilla",
        "- %APPDATA%\\Mozilla",
        "- %LOCALAPPDATA%\\Mozilla",
        "- %ProgramData%\\Mozilla-*"
    ],
    "architecture": {
        "64bit": {
            "url": "https://archive.mozilla.org/pub/firefox/releases/148.0/win64/ja/Firefox%20Setup%20148.0.exe#/dl.7z",
            "hash": "sha512:8805205405c70d5038ef307f5392d3ee76d8b43c5e7aa6da566b8e8fa7db0b649ef6ce56061b8026fa0ef4e05b8e24e3c4e15bb682a9de43dee335d9849b7ff7"
        }
    },
    "extract_dir": "core",
    "post_install": "firefox -CreateProfile \"Scoop $persist_dir\\profile\"",
    "bin": "firefox.exe",
    "shortcuts": [
        [
            "firefox.exe",
            "Firefox"
        ],
        [
            "firefox.exe",
            "Firefox Profile Manager",
            "-P"
        ]
    ],
    "persist": [
        "distribution",
        "profile"
    ],
    "checkver": {
        "url": "https://product-details.mozilla.org/1.0/firefox_versions.json",
        "jsonpath": "$.LATEST_FIREFOX_VERSION"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://archive.mozilla.org/pub/firefox/releases/$version/win64/ja/Firefox%20Setup%20$version.exe#/dl.7z",
                "hash": {
                    "url": "https://archive.mozilla.org/pub/firefox/releases/$version/SHA512SUMS",
                    "regex": "$sha512\\s+win64/ja/$basename"
                }
            }
        }
    }
}
